# PostgreSQL 配置
POSTGRES_USER=rsdp
POSTGRES_PASSWORD=rsdp

# MinIO 管理员密码（生产环境必须修改）
MINIO_ROOT_USER=minioadmin
MINIO_PASSWORD=minioadmin

# AES-256 加密密钥（Base64 编码的 32 字节密钥，生产环境必须修改）
# 生成示例：openssl rand -base64 32
RSDP_ENCRYPTION_KEY=WYs8rXkOCYazXad8RLS2lP5qmWI6fYPCd0HQ72fXSnY=

# DashScope API Key（MVP 阶段使用 qwen3-vl-plus）
DASHSCOPE_API_KEY=your-dashscope-api-key

# 产品批量导入时允许下载图片的 host 白名单，逗号分隔；留空表示仅允许公网地址
RSDP_IMPORT_ALLOWED_IMAGE_HOSTS=
