# RSDP 生产/本地部署环境变量模板
# 复制本文件为 deploy/.env 后，将所有 <CHANGE_ME> 替换为强随机值
# 切勿将真实 .env 提交到版本控制

# PostgreSQL 配置
POSTGRES_USER=rsdp
POSTGRES_PASSWORD=<CHANGE_ME>

# MinIO 管理员账号（生产环境必须修改）
MINIO_ROOT_USER=<CHANGE_ME>
MINIO_ROOT_PASSWORD=<CHANGE_ME>

# AES-256 加密密钥（Base64 编码的 32 字节密钥）
# 生成命令：openssl rand -base64 32
RSDP_ENCRYPTION_KEY=<CHANGE_ME>

# DashScope API Key（MVP 阶段使用 qwen3-vl-plus）
DASHSCOPE_API_KEY=<CHANGE_ME>

# JWT 签名密钥（Base64 编码的 32 字节密钥）
# 生成命令：openssl rand -base64 32
RSDP_JWT_SECRET=<CHANGE_ME>

# HttpOnly JWT Cookie 名称（可选，通常保持默认）
# RSDP_JWT_COOKIE_NAME=rsdp_token

# 生产环境必须为 true；本地 http 开发可设为 false
RSDP_JWT_COOKIE_SECURE=true

# 前端跨域来源白名单，逗号分隔；生产环境必须改为具体域名
RSDP_ALLOWED_ORIGINS=http://localhost:5173

# 产品批量导入时允许下载图片的 host 白名单，逗号分隔；留空表示仅允许公网地址
RSDP_IMPORT_ALLOWED_IMAGE_HOSTS=

# Redis 访问密码（生产环境必须修改）
REDIS_PASSWORD=<CHANGE_ME>

# ChromaDB Token 认证（可选；取消注释并设置凭证后，后端会自动携带 Authorization: Bearer 头）
# CHROMA_AUTH_PROVIDER=chromadb.auth.token_authn.TokenAuthenticationServerProvider
# CHROMA_AUTH_CREDENTIALS=<CHANGE_ME>

# 开发环境测试账号密码（当前已硬编码在 database/V1__seed_data.sql 中，统一为 rsdp-dev-2026!）
# 该变量暂未生效，保留仅作说明；生产环境请务必删除或修改 database/V1__seed_data.sql 中的默认账号
# RSDP_DEV_TEST_PASSWORD=rsdp-dev-2026!

# 开发环境图片存储本地路径（可选）
# RSDP_STORAGE_LOCAL_PATH=/absolute/path/to/server/data/uploads

# 订单客户邀请链接 HMAC 密钥，>=32 位随机串
RSDP_ORDER_INVITE_SECRET=<CHANGE_ME>
